<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:TipTracker.Controls"
             xmlns:viewModels="clr-namespace:TipTracker.ViewModels"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="600"
             x:Class="TipTracker.Controls.ServerLookupList"
			 x:DataType="viewModels:MainWindowViewModel">
	<Grid ColumnDefinitions="*"
		  RowDefinitions="Auto,*">
		<TextBlock Grid.Row="0" Text="Servers" />
		<DataGrid Grid.Row="1" 
				  ItemsSource="{Binding Servers}"
                  AutoGenerateColumns="false"
                  IsReadOnly="true"
                  GridLinesVisibility="All"
                  BorderThickness="1"
                  BorderBrush="Gray"
				  VerticalScrollBarVisibility="Visible"
				  >
			<DataGrid.Columns>
				<DataGridTextColumn Width="25*" Header="Number" Binding="{Binding Number}" />
				<DataGridTextColumn Width="30*" Header="Last Name" Binding="{Binding LastName}" />
				<DataGridTextColumn Width="45*" Header="First Name" Binding="{Binding FirstName}" />
			</DataGrid.Columns>
		</DataGrid>
	</Grid>
</UserControl>
